# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# Groq API key — obtain from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# LLM model identifier
GROQ_MODEL=llama-3.3-70b-versatile

# SQLite database file (used by SQLAlchemy / aiosqlite for claims history)
DATABASE_URL=sqlite+aiosqlite:///./claims.db
